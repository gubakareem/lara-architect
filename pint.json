{
    "preset": "laravel",
    "exclude": [
        "stubs"
    ],
    "rules": {
        "declare_strict_types": true,
        "blank_line_before_statement": {
            "statements": [
                "break",
                "continue",
                "declare",
                "return",
                "throw",
                "try"
            ]
        },
        "ordered_imports": {
            "imports_order": [
                "class",
                "function",
                "const"
            ]
        },
        "simplified_null_return": true,
        "trailing_comma_in_multiline": true,
        "array_syntax": {
            "syntax": "short"
        }
    }
}
